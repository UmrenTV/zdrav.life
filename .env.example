# ============================================
# ZdravLife Environment Variables
# ============================================

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://zdrav.life
NEXT_PUBLIC_SITE_NAME=ZdravLife

# SEO
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code

# Social Links
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@zdravlife
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/zdravlife
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/zdravlife
NEXT_PUBLIC_GITHUB_URL=https://github.com/zdravlife

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Newsletter (optional)
# NEXT_PUBLIC_CONVERTKIT_API_KEY=your_convertkit_key
# NEXT_PUBLIC_CONVERTKIT_FORM_ID=your_form_id

# E-commerce (optional - for future Stripe integration)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Database (optional - for future CMS integration)
# DATABASE_URL=postgresql://...
# SUPABASE_URL=https://...
# SUPABASE_ANON_KEY=...

# Search (optional - for future Algolia integration)
# ALGOLIA_APP_ID=...
# ALGOLIA_API_KEY=...
# ALGOLIA_INDEX_NAME=...
