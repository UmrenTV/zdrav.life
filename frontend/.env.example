# Site Configuration
NEXT_PUBLIC_SITE_URL=https://zdrav.life
NEXT_PUBLIC_SITE_NAME=ZdravLife

# SEO
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code

# Social Links
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@zdravlife
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/zdravlife
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/zdravlife
