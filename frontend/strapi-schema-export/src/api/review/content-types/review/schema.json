{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "product": { "type": "relation", "relation": "manyToOne", "target": "api::product.product" },
    "authorName": { "type": "string", "required": true },
    "rating": { "type": "integer", "required": true },
    "title": { "type": "string" },
    "content": { "type": "text" },
    "verifiedPurchase": { "type": "boolean", "default": false },
    "helpfulCount": { "type": "integer", "default": 0 },
    "approved": { "type": "boolean", "default": false },
    "createdAtOverride": { "type": "datetime" }
  }
}
